{
  "name": "@dsbuilder/tokens",
  "version": "0.0.0",
  "description": "W3C DTCG token compiler with hybrid semantic/component architecture",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@dsbuilder/eslint-config": "workspace:*",
    "@dsbuilder/typescript-config": "workspace:*",
    "@types/node": "^22.19.15",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
